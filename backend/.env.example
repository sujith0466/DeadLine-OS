# ============================================================
# DeadlineOS — Backend Environment Configuration Example
# ============================================================

# --- Flask & Application ---
# development, testing, production
FLASK_ENV=development
# Secret key for Flask sessions
FLASK_SECRET_KEY=your-super-secret-flask-key

# --- Database ---
# Neon PostgreSQL Connection String (Transaction Pooler recommended)
DATABASE_URL=postgresql://user:pass@ep-rest-of-host.eu-central-1.aws.neon.tech/dbname?sslmode=require

# --- Authentication (Supabase) ---
# Supabase project URL
SUPABASE_URL=https://your-project.supabase.co
# JWT Secret for verifying auth tokens
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
# Admin operations key (Service Role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Public anonymous key
SUPABASE_ANON_KEY=your-anon-key

# --- AI Intelligence (Gemini) ---
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_VISION_MODEL=gemini-2.0-flash

# --- CORS & Security ---
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,https://deadlineos.vercel.app

# --- Observability ---
# SENTRY_DSN=your-sentry-dsn
LOG_LEVEL=INFO

# --- Demo Mode ---
DEMO_USER_EMAIL=demo@deadlineos.com
DEMO_USER_PASSWORD=your-secure-demo-password
