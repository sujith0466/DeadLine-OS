# ==============================================================================
# DeadlineOS — Global .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Environment & Secrets (NEVER COMMIT)
# ------------------------------------------------------------------------------
.env
.env.*
!.env.example
backend/.env
frontend/.env
*.pem
*.key
*.crt
*.p12
*.pfx

# ------------------------------------------------------------------------------
# 2. Python & Backend
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
coverage.xml
backend/instance/
*.db
*.sqlite
*.sqlite3

# Virtual Environments
.venv/
venv/
env/
ENV/

# ------------------------------------------------------------------------------
# 3. Node, React & Frontend
# ------------------------------------------------------------------------------
node_modules/
dist/
build/
.vite/
vite.svg
coverage/

# ------------------------------------------------------------------------------
# 4. Logs & Caches
# ------------------------------------------------------------------------------
logs/
*.log
*.stackdump
.cache/
backend/audit_results.json
runtime_cache/
tmp/
temp/

# ------------------------------------------------------------------------------
# 5. OS & IDE
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*.bak

# ------------------------------------------------------------------------------
# 6. Temporary / Obsolete Historical Reports
# ------------------------------------------------------------------------------
# Ignore historical phase markdown files scattered in root
PHASE_*.md
*_REPORT.md
*_CERTIFICATION.md
*_AUDIT.md
*_VALIDATION.md
!DEPLOYMENT_AUDIT_REPORT.md
docs/verification/

# ------------------------------------------------------------------------------
# 7. Deployment / Services Artifacts
# ------------------------------------------------------------------------------
.vercel
.render
puppeteer/
.puppeteerrc.cjs
verify_browser.*

# Ignore temporary testing scripts
backend/run_audit.py
backend/test_smoke.py
frontend/strip_mock.py
frontend/audit_console.cjs